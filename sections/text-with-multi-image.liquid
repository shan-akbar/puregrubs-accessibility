<style>
     @import url('https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap');
     @font-face {
       font-family: 'Noto_Sans_Condensed_bold';
       src: url('https://cdn.shopify.com/s/files/1/0954/7926/7646/files/NotoSans-ExtraCondensedExtraBold.ttf?v=1777383522');
     }
  .science-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 0;
    font-family: inherit;
  }

  .science-container-{{ section.id }} {
    display: flex;
    align-items: center;

    gap: 50px;
    flex-wrap: wrap;
  }

  .science-content-{{ section.id }} {
    flex: 1;
    max-width: 600px;
  }

  .science-heading-{{ section.id }} {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    margin-bottom: 20px;
    line-height: 1.2;
    font-family: 'Noto_Sans_Condensed_bold';
  }

  .science-description-{{ section.id }} {
    color: {{ section.settings.desc_color }};
    font-size: {{ section.settings.desc_size }}px;
    font-weight: {{ section.settings.desc_weight }};
    text-transform: {{ section.settings.desc_transform }};
    margin-bottom: 40px;
    line-height: 1.6;
    font-family: 'Noto Sans', sans-serif;
  }

  .science-features-{{ section.id }} {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content:space-between;
  }

  .science-feature-block {
    flex: 1;
    max-width: 130px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .science-image-container-{{ section.id }} {
    flex: 1;
    display: flex;
    justify-content: center;
    max-width: {{ section.settings.main_image_width }}px;
    width: 100%;
    height: auto;
    margin-top:5rem;
  }

   .science-image-container-{{ section.id }} img{
    width:100%;
    object-fit:cover;
    object-position:center;
  }

  .science-feature-block p{
    font-family: 'Noto Sans', sans-serif;
  }
  @media (max-width: 768px) {
    .science-container-{{ section.id }} {
      gap: 0 !important;
    }
     .science-section-{{ section.id }} {
      padding: 30px 0px;
     }
    .science-container-{{ section.id }} {
      flex-direction: column;
      text-align: center;
    }
    .science-features-{{ section.id }} {
      justify-content: center;
    }

    .science-features-{{ section.id }} {
   
      gap: 10px;
  
    }
  }
  @media screen and (max-width:375px){
  .science-feature-block img{
    width:60px !important;
  }
  .science-feature-block p{
    font-size:12px !important;
  }
  }
</style>

<div class="science-section-{{ section.id }}">
  <div class="science-container-{{ section.id }} page-width">
    <div class="science-content-{{ section.id }}">
      {% if section.settings.heading != blank %}
        <h2 class="science-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="science-description-{{ section.id }}">{{ section.settings.description }}</div>
      {% endif %}

      <div class="science-features-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="science-feature-block" {{ block.shopify_attributes }}>
            {% if block.settings.icon_image != blank %}
              <img
                src="{{ block.settings.icon_image | img_url: 'master' }}"
                alt="{{ block.settings.icon_image.alt | escape }}"
                style="width: {{ block.settings.icon_width }}px; height: auto; margin-bottom: 15px;"
                loading="lazy"
              >
            {% endif %}

            {% if block.settings.feature_text != blank %}
              <p
                style="
                  color: {{ block.settings.text_color }};
                  font-size: {{ block.settings.text_size }}px;
                  font-weight: {{ block.settings.text_weight }};
                  text-transform: {{ block.settings.text_transform }};
                  margin: 0;
                  line-height: 1.4;
                "
              >
                {{ block.settings.feature_text }}
              </p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="science-image-container-{{ section.id }}">
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | img_url: 'master' }}"
          alt="{{ section.settings.main_image.alt | escape }}"
          style=""
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Text with multiple image",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4ede1"
    },
    {
      "type": "header",
      "content": "Heading Settings"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading Text",
      "default": "THE SCIENCE BEHIND NATURE'S PERFECT PROTEIN"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#6b5e48"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 40
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "bold", "label": "Bold" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "bold"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Description Settings"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text",
      "default": "<p>Black Soldier Fly Larvae (BSFL) are nature's most efficient source of complete protein...</p>"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Description Font Size",
      "default": 16
    },
    {
      "type": "select",
      "id": "desc_weight",
      "label": "Description Font Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "bold", "label": "Bold" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "desc_transform",
      "label": "Description Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Main Image Settings"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image (Flask)"
    },
    {
      "type": "range",
      "id": "main_image_width",
      "min": 10,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Image Width Relative to Container",
      "default": 400
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Icon",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "range",
          "id": "icon_width",
          "min": 20,
          "max": 150,
          "step": 5,
          "unit": "px",
          "label": "Icon Width",
          "default": 60
        },
        {
          "type": "textarea",
          "id": "feature_text",
          "label": "Feature Text",
          "default": "Feature description goes here"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#333333"
        },
        {
          "type": "range",
          "id": "text_size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "label": "Font Size",
          "default": 14
        },
        {
          "type": "select",
          "id": "text_weight",
          "label": "Font Weight",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "bold", "label": "Bold" }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" }
          ],
          "default": "none"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text with multiple image",
      "blocks": [{ "type": "feature" }, { "type": "feature" }, { "type": "feature" }]
    }
  ]
}
{% endschema %}
